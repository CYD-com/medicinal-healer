page {
  --primary: #4A90D9;
  --primary-dark: #357ABD;
  --bg: #f5f7fa;
  --card: #ffffff;
  --text: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --border: #f0f0f0;
  --shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  --radius: 16rpx;
  --radius-sm: 12rpx;
  --radius-lg: 24rpx;

  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, system-ui, sans-serif;
  font-size: 28rpx;
  color: var(--text);
  line-height: 1.5;
  box-sizing: border-box;
}

.container {
  padding: 24rpx 30rpx;
}

.card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 20rpx;
  display: block;
}

.empty-tip {
  text-align: center;
  color: var(--text-hint);
  padding: 80rpx 0;
  font-size: 28rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
  color: var(--text-hint);
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-right: 8rpx;
}

.tag-primary  { background: rgba(74,144,217,0.10); color: #4A90D9; }
.tag-success  { background: rgba(82,196,26,0.10);  color: #52c41a; }
.tag-warning  { background: rgba(250,173,20,0.10); color: #faad14; }
.tag-danger   { background: rgba(245,108,108,0.10); color: #f56c6c; }
.tag-info     { background: rgba(144,147,153,0.10); color: #909399; }

.btn-primary {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  padding: 26rpx 0;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  width: 100%;
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.3);
}
.btn-primary::after { border: none; }
.btn-primary[disabled] {
  background: #c8d6e5;
  color: #fff;
  box-shadow: none;
}

.btn-outline {
  background: #fff;
  color: #4A90D9;
  border: 2rpx solid #4A90D9;
  border-radius: 44rpx;
  padding: 26rpx 0;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
}
.btn-outline::after { border: none; }

.btn-outline-danger {
  background: #fff;
  color: #f56c6c;
  border: 2rpx solid #f56c6c;
  border-radius: 44rpx;
  padding: 26rpx 0;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
}
.btn-outline-danger::after { border: none; }

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #4A90D9;
  font-size: 26rpx;
}