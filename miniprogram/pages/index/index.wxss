.home-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 140rpx;
}

.header {
  background: linear-gradient(160deg, #4A90D9 0%, #3a7bc8 40%, #2d6ab0 100%);
  padding: 50rpx 36rpx 60rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-radius: 0 0 40rpx 40rpx;
}

.greeting {
  display: flex;
  flex-direction: column;
}

.greeting .hello {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.greeting .welcome {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
}

.avatar-wrap {
  position: relative;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.4);
}

.banner {
  margin: -28rpx 30rpx 30rpx;
}

.swiper {
  height: 260rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-item {
  height: 260rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 50rpx;
}

.banner-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 14rpx;
}

.banner-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

.services {
  padding: 0 30rpx;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  display: block;
}

.service-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
  transition: transform 0.15s;
}

.service-item:active {
  transform: scale(0.95);
}

.service-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.service-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.quick-actions {
  padding: 0 30rpx;
}

.action-card {
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
  overflow: hidden;
}

.action-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.15s;
}

.action-item:last-child {
  border-bottom: none;
}

.action-item:active {
  background: #f9f9f9;
}

.action-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 32rpx;
}

.action-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.action-arrow {
  font-size: 36rpx;
  color: #d0d0d0;
}