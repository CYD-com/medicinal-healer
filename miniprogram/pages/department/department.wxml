<view class="department-page">
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{departments.length === 0}}" class="empty-tip">
    <text>暂无科室信息</text>
  </view>

  <view wx:else class="dept-list">
    <view
      class="dept-card"
      wx:for="{{departments}}"
      wx:key="id"
      bindtap="goDepartment"
      data-id="{{item.id}}"
      data-name="{{item.name}}"
    >
      <view class="dept-icon-wrap">
        <text class="dept-icon">🏥</text>
      </view>
      <view class="dept-info">
        <text class="dept-name">{{item.name}}</text>
        <text class="dept-desc">{{item.description || '暂无描述'}}</text>
        <text class="dept-count">医生数量：{{item.doctorsCount || 0}}人</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>
</view>