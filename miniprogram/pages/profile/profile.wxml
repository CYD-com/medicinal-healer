<view class="profile-page">
  <view class="user-header">
    <view class="avatar-section" bindtap="changeAvatar">
      <image class="avatar" src="{{userInfo && userInfo.avatar ? baseUrl + userInfo.avatar : '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <text class="change-avatar">更换头像</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.realName || userInfo.username}}</text>
      <text class="user-role">{{roleText}}</text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-group">
      <view class="menu-item" bindtap="goEditProfile">
        <text class="menu-icon">👤</text>
        <text class="menu-text">个人信息</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goHealthRecord">
        <text class="menu-icon">📋</text>
        <text class="menu-text">健康档案</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goPrescription">
        <text class="menu-icon">💊</text>
        <text class="menu-text">我的处方</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-group">
      <view class="menu-item" bindtap="changePassword">
        <text class="menu-icon">🔒</text>
        <text class="menu-text">修改密码</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goAbout">
        <text class="menu-icon">ℹ️</text>
        <text class="menu-text">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <button class="logout-btn" bindtap="onLogout">退出登录</button>

  <view wx:if="{{showPasswordModal}}" class="modal-mask" bindtap="closePasswordModal">
    <view class="modal-content" catchtap>
      <text class="modal-title">修改密码</text>
      <view class="form-item">
        <text class="label">原密码</text>
        <input class="input" placeholder="请输入原密码" password value="{{passwordForm.oldPassword}}" bindinput="onPasswordInput" data-field="oldPassword" />
      </view>
      <view class="form-item">
        <text class="label">新密码</text>
        <input class="input" placeholder="请输入新密码" password value="{{passwordForm.newPassword}}" bindinput="onPasswordInput" data-field="newPassword" />
      </view>
      <view class="form-item">
        <text class="label">确认密码</text>
        <input class="input" placeholder="请再次输入新密码" password value="{{passwordForm.confirmPassword}}" bindinput="onPasswordInput" data-field="confirmPassword" />
      </view>
      <view class="modal-actions">
        <button class="btn-outline" bindtap="closePasswordModal">取消</button>
        <button class="btn-primary" bindtap="submitPassword">确认</button>
      </view>
    </view>
  </view>
</view>