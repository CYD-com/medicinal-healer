.profile-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 140rpx;
}

.user-header {
  background: linear-gradient(160deg, #4A90D9, #357ABD);
  padding: 60rpx 36rpx 50rpx;
  display: flex;
  align-items: center;
  border-radius: 0 0 40rpx 40rpx;
}

.avatar-section {
  position: relative;
  margin-right: 28rpx;
}

.avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  border: 5rpx solid rgba(255,255,255,0.4);
}

.change-avatar {
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: #fff;
  background: rgba(0,0,0,0.35);
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  white-space: nowrap;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
}

.user-role {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.2);
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

.menu-section {
  padding: 30rpx 30rpx 0;
}

.menu-group {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background 0.15s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #f9f9f9;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 50rpx;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.menu-arrow {
  font-size: 32rpx;
  color: #d0d0d0;
}

.logout-btn {
  margin: 40rpx 30rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  color: #f56c6c;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: 2rpx solid #f56c6c;
}

.logout-btn::after {
  border: none;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
}

.modal-content .form-item {
  margin-bottom: 24rpx;
}

.modal-content .label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.modal-content .input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-actions .btn-outline,
.modal-actions .btn-primary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  padding: 0;
}