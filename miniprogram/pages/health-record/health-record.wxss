.health-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: 80rpx;
}

.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #4A90D9;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #4A90D9;
  border-radius: 2rpx;
}

.tab-content {
  padding: 20rpx 30rpx;
}

.summary-card {
  display: flex;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 20rpx;
  justify-content: space-around;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-row .label {
  font-size: 26rpx;
  color: #999;
}

.info-row .value {
  font-size: 28rpx;
  color: #333;
}

.visit-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.visit-item:last-child {
  border-bottom: none;
}

.visit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.visit-dept {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.visit-date {
  font-size: 22rpx;
  color: #999;
}

.visit-diagnosis {
  font-size: 24rpx;
  color: #666;
}

.visit-card {
  cursor: pointer;
}

.visit-doctor {
  font-size: 24rpx;
  color: #666;
  display: block;
  margin-bottom: 6rpx;
}

.history-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-item:last-child {
  border-bottom: none;
}

.disease-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.disease-time {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 6rpx;
}

.disease-desc {
  font-size: 24rpx;
  color: #666;
}

.indicator-selector {
  margin-bottom: 20rpx;
}

.filter-item {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.filter-item .arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: #999;
}

.indicator-card {
  margin-bottom: 16rpx;
}

.indicator-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.indicator-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.indicator-date {
  font-size: 22rpx;
  color: #999;
}

.indicator-status {
  font-size: 24rpx;
}

.indicator-status.normal {
  color: #52c41a;
}

.indicator-status.abnormal {
  color: #f5222d;
}

.add-btn {
  margin-top: 30rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
}

.modal-content .form-item {
  margin-bottom: 24rpx;
}

.modal-content .label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.modal-content .input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-input {
  display: flex;
  align-items: center;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-actions .btn-outline,
.modal-actions .btn-primary {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}