.register-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 0 40rpx;
}

.header {
  padding: 60rpx 0 40rpx;
  text-align: center;
}

.header .title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.form {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item .label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-item .input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.captcha-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.captcha-input {
  flex: 1;
}

.captcha-img {
  width: 200rpx;
  height: 80rpx;
  border-radius: 12rpx;
  border: 1rpx solid #eee;
}

.captcha-tip {
  display: block;
  font-size: 22rpx;
  color: #4A90D9;
  margin-top: 8rpx;
  text-align: right;
}

.btn-primary {
  margin-top: 20rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
}

.login-link {
  text-align: center;
  margin-top: 30rpx;
  font-size: 26rpx;
  color: #999;
  padding-bottom: 40rpx;
}

.login-link .link {
  color: #4A90D9;
  margin-left: 10rpx;
}
