<view class="register-page">
  <view class="header">
    <text class="title">用户注册</text>
  </view>

  <view class="form">
    <view class="form-item">
      <text class="label">用户名 *</text>
      <input class="input" placeholder="请输入用户名（3-20位）" value="{{form.username}}" bindinput="onInput" data-field="username" maxlength="20" />
    </view>

    <view class="form-item">
      <text class="label">密码 *</text>
      <input class="input" placeholder="请输入密码（6-20位）" password value="{{form.password}}" bindinput="onInput" data-field="password" maxlength="20" />
    </view>

    <view class="form-item">
      <text class="label">确认密码 *</text>
      <input class="input" placeholder="请再次输入密码" password value="{{form.confirmPassword}}" bindinput="onInput" data-field="confirmPassword" maxlength="20" />
    </view>

    <view class="form-item">
      <text class="label">验证码 *</text>
      <view class="captcha-row">
        <input class="input captcha-input" placeholder="请输入验证码" value="{{form.code}}" bindinput="onInput" data-field="code" maxlength="4" />
        <image class="captcha-img" src="{{captchaImage}}" mode="aspectFit" bindtap="refreshCaptcha" />
      </view>
      <text class="captcha-tip" bindtap="refreshCaptcha">看不清楚？换一张</text>
    </view>

    <button class="btn-primary" bindtap="onRegister" disabled="{{loading}}">
      {{loading ? '注册中...' : '注 册'}}
    </button>

    <view class="login-link">
      <text>已有账号？</text>
      <text class="link" bindtap="goLogin">返回登录</text>
    </view>
  </view>
</view>
