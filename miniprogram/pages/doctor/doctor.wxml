<view class="doctor-page">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索医生姓名" value="{{keyword}}" bindinput="onSearchInput" />
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>

  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <view wx:elif="{{doctors.length === 0}}" class="empty-tip">
    <text>暂无医生信息</text>
  </view>

  <view wx:else class="doctor-list">
    <view
      class="doctor-card"
      wx:for="{{doctors}}"
      wx:key="doctorId"
      bindtap="selectDoctor"
      data-id="{{item.doctorId}}"
    >
      <image class="doctor-avatar" src="{{item.avatar ? baseUrl + item.avatar : '/images/default-avatar.png'}}" mode="aspectFill"></image>
      <view class="doctor-info">
        <view class="name-row">
          <text class="doctor-name">{{item.name}}</text>
          <text class="doctor-title">{{item.title}}</text>
        </view>
        <text class="doctor-dept">{{item.department.name}}</text>
        <view class="specialties">
          <text class="tag tag-primary" wx:for="{{item.specialty}}" wx:for-item="spec" wx:key="*this">{{spec}}</text>
        </view>
        <view class="stats">
          <text class="stat-item">评分 {{item.rating || '5.0'}}</text>
          <text class="stat-item">问诊 {{item.consultationCount || 0}}次</text>
        </view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <view wx:if="{{hasMore && !loading}}" class="load-more" bindtap="loadMore">
    <text>加载更多</text>
  </view>
</view>