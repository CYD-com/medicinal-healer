.doctor-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx 30rpx 80rpx;
}

.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  background: #fff;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.search-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 30rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
}

.search-btn::after {
  border: none;
}

.doctor-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.doctor-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.doctor-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #f0f0f0;
  flex-shrink: 0;
}

.doctor-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.doctor-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.doctor-title {
  font-size: 22rpx;
  color: #4A90D9;
  background: #e8f4fd;
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
}

.doctor-dept {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 10rpx;
}

.specialties {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 10rpx;
}

.stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  font-size: 22rpx;
  color: #999;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 16rpx;
}

.load-more {
  text-align: center;
  padding: 30rpx;
  color: #4A90D9;
  font-size: 26rpx;
}