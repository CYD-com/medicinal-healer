<view class="appointment-page">
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'list' ? 'active' : ''}}" bindtap="switchTab" data-tab="list">
      <text>我的预约</text>
    </view>
    <view class="tab-item {{currentTab === 'new' ? 'active' : ''}}" bindtap="switchTab" data-tab="new">
      <text>新建预约</text>
    </view>
  </view>

  <view wx:if="{{currentTab === 'list'}}">
    <view class="filter-bar">
      <picker bindchange="onStatusChange" value="{{statusIndex}}" range="{{statusList}}" range-key="label">
        <view class="filter-item">
          <text>{{statusList[statusIndex].label}}</text>
          <text class="arrow">▼</text>
        </view>
      </picker>
    </view>

    <view class="list-container">
      <view wx:if="{{loading}}" class="loading">
        <text>加载中...</text>
      </view>

      <view wx:elif="{{appointments.length === 0}}" class="empty-tip">
        <text>暂无预约记录</text>
      </view>

      <view wx:else>
        <view class="appointment-card" wx:for="{{appointments}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
          <view class="card-header">
            <text class="dept-name">{{item.departmentName}}</text>
            <text class="tag {{item.statusClass}}">{{item.statusText}}</text>
          </view>
          <view class="card-body">
            <view class="info-row">
              <text class="label">医生：</text>
              <text class="value">{{item.doctorName}}</text>
            </view>
            <view class="info-row">
              <text class="label">时间：</text>
              <text class="value">{{item.appointmentDate}} {{item.timeSlotDisplay}}</text>
            </view>
            <view class="info-row">
              <text class="label">就诊人：</text>
              <text class="value">{{item.patientName}}</text>
            </view>
          </view>
          <view class="card-footer" wx:if="{{item.status === 'pending' || item.status === 'confirmed'}}">
            <button class="btn-outline btn-sm" catchtap="onCancel" data-id="{{item.id}}">取消预约</button>
          </view>
        </view>
      </view>

      <view wx:if="{{hasMore && !loading}}" class="load-more" bindtap="loadMore">
        <text>加载更多</text>
      </view>
    </view>
  </view>

  <view wx:if="{{currentTab === 'new'}}">
    <view class="dept-list">
      <view class="section-title">选择科室</view>
      <view class="dept-grid">
        <view
          class="dept-item {{selectedDeptId === item.id ? 'selected' : ''}}"
          wx:for="{{departments}}"
          wx:key="id"
          bindtap="selectDepartment"
          data-id="{{item.id}}"
          data-name="{{item.name}}"
        >
          <text class="dept-icon">🏥</text>
          <text class="dept-name">{{item.name}}</text>
        </view>
      </view>

      <view wx:if="{{selectedDeptId}}" class="section-title" style="margin-top: 30rpx;">
        选择医生
      </view>
      <view wx:if="{{doctors.length > 0}}" class="doctor-list">
        <view
          class="doctor-card"
          wx:for="{{doctors}}"
          wx:key="doctorId"
          bindtap="selectDoctor"
          data-id="{{item.doctorId}}"
        >
          <image class="doctor-avatar" src="{{item.avatar ? baseUrl + item.avatar : '/images/default-avatar.png'}}" mode="aspectFill"></image>
          <view class="doctor-info">
            <text class="doctor-name">{{item.name}}</text>
            <text class="doctor-title">{{item.title}}</text>
            <view class="specialties">
              <text class="tag tag-primary" wx:for="{{item.specialty}}" wx:for-item="spec" wx:key="*this">{{spec}}</text>
            </view>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>

      <view wx:if="{{selectedDeptId && doctors.length === 0 && !loading}}" class="empty-tip">
        <text>该科室暂无医生</text>
      </view>
    </view>
  </view>
</view>