.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #4A90D9 0%, #357ABD 45%, #f5f7fa 45%);
  padding: 0 40rpx;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 180rpx;
  padding-bottom: 60rpx;
}

.logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 36rpx;
  margin-bottom: 28rpx;
  background: #fff;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.75);
}

.login-form {
  background: #fff;
  border-radius: 28rpx;
  padding: 56rpx 40rpx 40rpx;
  box-shadow: 0 8rpx 48rpx rgba(0,0,0,0.08);
}

.form-item {
  position: relative;
  margin-bottom: 36rpx;
}

.form-item .label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 14rpx;
}

.form-item .input {
  width: 100%;
  height: 92rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.eye-icon {
  position: absolute;
  right: 24rpx;
  bottom: 22rpx;
  font-size: 36rpx;
  z-index: 1;
}

.login-btn {
  margin-top: 30rpx;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 46rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.register-link {
  text-align: center;
  margin-top: 36rpx;
  font-size: 26rpx;
  color: #999;
}

.register-link .link {
  color: #4A90D9;
  margin-left: 8rpx;
  font-weight: 500;
}