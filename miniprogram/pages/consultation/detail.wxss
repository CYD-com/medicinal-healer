.detail-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f7fa;
}

.consultation-info {
  background: #fff;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.info-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-header .doctor-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.consultation-info .symptoms {
  font-size: 24rpx;
  color: #666;
}

.message-list {
  flex: 1;
  padding: 20rpx 30rpx;
  overflow-y: auto;
}

.empty-messages {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 26rpx;
}

.message-item {
  display: flex;
  margin-bottom: 24rpx;
}

.message-item.self {
  justify-content: flex-end;
}

.message-item.other {
  justify-content: flex-start;
}

.message-bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  position: relative;
}

.message-item.self .message-bubble {
  background: #4A90D9;
  color: #fff;
  border-bottom-right-radius: 4rpx;
}

.message-item.other .message-bubble {
  background: #fff;
  color: #333;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.message-content {
  font-size: 28rpx;
  display: block;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.message-time {
  font-size: 20rpx;
  opacity: 0.7;
  display: block;
  text-align: right;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  gap: 16rpx;
}

.message-input {
  flex: 1;
  height: 72rpx;
  background: #f5f7fa;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.send-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 30rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 36rpx;
  font-size: 28rpx;
  border: none;
  min-width: 120rpx;
}

.send-btn::after {
  border: none;
}

.send-btn[disabled] {
  background: #ccc;
  color: #999;
}

.completed-tip {
  text-align: center;
  padding: 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  color: #999;
  font-size: 26rpx;
}