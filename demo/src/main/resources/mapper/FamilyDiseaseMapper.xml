<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.usergenerator.mapper.FamilyDiseaseMapper">
    <select id="selectByUserId" resultType="com.example.usergenerator.entity.FamilyDisease">
        SELECT id, user_id, disease_name, relation, remark, created_at
        FROM family_disease
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
    </select>
</mapper>
