<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.usergenerator.mapper.DepartmentMapper">
    <resultMap id="BaseResultMap" type="com.example.usergenerator.entity.Department">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="description" property="description"/>
        <result column="doctors_count" property="doctorsCount"/>
    </resultMap>
    <sql id="Base_Column_List">id, name, description, doctors_count</sql>
    <select id="selectAllDepartments" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM t_department ORDER BY id ASC
    </select>
    <select id="selectDepartmentById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM t_department WHERE id = #{id}
    </select>
</mapper>