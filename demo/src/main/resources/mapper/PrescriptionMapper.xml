<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.usergenerator.mapper.PrescriptionMapper">

    <resultMap id="BaseResultMap" type="com.example.usergenerator.entity.Prescription">
        <id column="prescription_id" property="id" />
        <result column="prescription_no" property="prescriptionNo" />
        <result column="user_id" property="userId" />
        <result column="doctor_id" property="doctorId" />
        <result column="diagnosis" property="diagnosis" />
        <result column="doctor_advice" property="doctorAdvice" />
        <result column="total_amount" property="totalAmount" />
        <result column="drug_count" property="drugCount" />
        <result column="status" property="status" />
        <result column="valid_until" property="validUntil" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
        <result column="deleted" property="deleted" />
    </resultMap>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM t_prescription WHERE user_id = #{userId} AND deleted = 0 ORDER BY created_at DESC
    </select>

    <select id="selectByUserIdAndStatus" resultMap="BaseResultMap">
        SELECT * FROM t_prescription WHERE user_id = #{userId} AND status = #{status} AND deleted = 0 ORDER BY created_at DESC
    </select>

    <select id="selectByDoctorId" resultMap="BaseResultMap">
        SELECT * FROM t_prescription WHERE doctor_id = #{doctorId} AND deleted = 0 ORDER BY created_at DESC
    </select>

    <select id="selectByDoctorIdAndStatus" resultMap="BaseResultMap">
        SELECT * FROM t_prescription WHERE doctor_id = #{doctorId} AND status = #{status} AND deleted = 0 ORDER BY created_at DESC
    </select>

</mapper>
