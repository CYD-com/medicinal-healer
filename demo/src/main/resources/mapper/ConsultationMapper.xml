<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.usergenerator.mapper.ConsultationMapper">

    <resultMap id="BaseResultMap" type="com.example.usergenerator.entity.Consultation">
        <id column="id" property="id" />
        <result column="consultation_no" property="consultationNo" />
        <result column="user_id" property="userId" />
        <result column="doctor_id" property="doctorId" />
        <result column="consultation_type" property="consultationType" />
        <result column="symptom" property="symptom" />
        <result column="description" property="description" />
        <result column="images" property="images" />
        <result column="medical_history" property="medicalHistory" />
        <result column="current_medication" property="currentMedication" />
        <result column="doctor_reply" property="doctorReply" />
        <result column="diagnosis" property="diagnosis" />
        <result column="status" property="status" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
        <result column="deleted" property="deleted" />
    </resultMap>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM consultation WHERE user_id = #{userId} AND deleted = 0 ORDER BY created_at DESC
    </select>

    <select id="selectByUserIdAndStatus" resultMap="BaseResultMap">
        SELECT * FROM consultation WHERE user_id = #{userId} AND status = #{status} AND deleted = 0 ORDER BY created_at DESC
    </select>

    <select id="selectByDoctorId" resultMap="BaseResultMap">
        SELECT * FROM consultation WHERE doctor_id = #{doctorId} AND deleted = 0 ORDER BY created_at DESC
    </select>

    <select id="selectByDoctorIdAndStatus" resultMap="BaseResultMap">
        SELECT * FROM consultation WHERE doctor_id = #{doctorId} AND status = #{status} AND deleted = 0 ORDER BY created_at DESC
    </select>

</mapper>